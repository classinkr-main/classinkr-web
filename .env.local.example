# ============================================================
# Classin Home example environment variables
# Copy this file to .env.local and fill in the real values.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Legacy admin auth fallback
# role: "admin" = full access
# role: "branch" = branch-scoped access
ADMIN_USERS=[{"name":"홍길동","password":"your-admin-pw","role":"admin"},{"name":"부산지사장","password":"your-branch-pw","role":"branch","branch":"부산지사"}]
# ADMIN_PASSWORD=your-admin-password

# Existing webhook integrations
GOOGLE_SHEET_WEBHOOK_URL=
LEAD_WEBHOOK_URL=
CHANNEL_TALK_WEBHOOK_URL=
EMAIL_WEBHOOK_URL=
